# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# GROQ_API_KEY: Optional Groq Cloud API Key. If you prefer to use Groq API (such as Llama 3.3 70B), define it here.
# Alternatively, pasting your Groq API Key (starts with 'gsk_') directly in the Gemini Secrets input will auto-detect and switch to Groq!
GROQ_API_KEY="MY_GROQ_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MONGODB_URI: Connection string for your MongoDB database/cluster.
# This applet uses MongoDB for cloud data persistence with high-performance bulk writes.
# If left blank, it falls back gracefully to a fully functional local JSON database.
MONGODB_URI="mongodb+srv://<username>:<password>@cluster.mongodb.net/study_buddy?retryWrites=true&w=majority"

